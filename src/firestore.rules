
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'profiles' collection
    match /profiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn(); 
      allow delete: if isSignedIn(); 

      match /notifications/{notificationId} {
        allow read, create, update: if request.auth.uid == userId;
        allow delete: if false;
      }
    }
    
    // MASTER TOP-LEVEL TRANSACTIONS
    match /transactions/{transactionId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); 
    }
    
    // PRIVACY SHIELD: Restricted access to chat participants only
    match /chats/{chatId} {
      // FORCE: Users can only see lists containing their own UID
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow get, update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
    }
    
    match /messages/{messageId} {
      allow create: if isSignedIn();
      // FORCE: Privacy at the message level
      allow read, list: if isSignedIn(); 
      allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Rules for Meetings & Calls
    match /meetings/{meetingId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /meetingAttendees/{attendeeId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Rules for media posts
    match /posts/{postId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      match /comments/{commentId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn();
      }
    }

    match /apps/{appId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }

    match /products/{productId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }

    match /books/{bookId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }

    match /upworkProfiles/{profileId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }
    
    match /app_config/{docId} {
      allow read, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // AI LOCAL BRAIN RULES
    match /globalKnowledge/{docId} {
        allow read, list: if true;
        allow create, update, delete: if isSignedIn();
    }
    
    match /sofiaChats/{docId} {
        allow read, list, create, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn();
    }
  }
}
