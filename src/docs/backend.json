{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "username": { "type": "string", "description": "The user's chosen username." },
        "country": { "type": "string", "description": "The user's country." },
        "pin": { "type": "string", "description": "The user's 5-digit transaction PIN (should be stored securely, e.g., hashed)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the profile was created." },
        "firstName": { "type": "string", "description": "The user's first name." },
        "lastName": { "type": "string", "description": "The user's last name." },
        "middleName": { "type": "string", "description": "The user's middle name (optional)." },
        "phone": { "type": "string", "description": "The user's phone number." },
        "bvn": { "type": "string", "description": "The user's Bank Verification Number." },
        "accountNumber": { "type": "string", "description": "The user's generated virtual account number." },
        "bankName": { "type": "string", "description": "The bank name for the virtual account." },
        "avatar": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." },
        "nairaBalance": { "type": "number", "description": "The user's main account balance in Naira." },
        "rewardBalance": { "type": "number", "description": "The user's reward points balance." },
        "clickCount": { "type": "number", "description": "The user's click count for rewards." },
        "hasReferral": { "type": "boolean", "description": "Whether the user has used a referral code." },
        "blockedUsers": { "type": "array", "items": { "type": "string" }, "description": "An array of user UIDs that this user has blocked."},
        "following": { "type": "array", "items": { "type": "string" }, "description": "An array of user UIDs that this user is following." },
        "followers": { "type": "array", "items": { "type": "string" }, "description": "An array of user UIDs that follow this user." }
      },
      "required": ["uid", "email", "createdAt", "username", "country", "pin"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Represents a notification for a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["system", "social", "like", "comment", "message", "follow"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string", "description": "An optional link for the notification to navigate to."}
      },
      "required": ["title", "description", "type", "isRead", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a financial transaction made by a user.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "The type of transaction.",
          "enum": ["transfer", "airtime", "data", "electricity", "tv_subscription", "deposit", "reward_withdrawal", "school_payment"]
        },
        "amount": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["completed", "pending", "failed"]
        },
        "recipientName": { "type": "string", "description": "Name of the recipient or service." },
        "recipientDetails": { "type": "string", "description": "Account number, phone number, or meter number." },
        "narration": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string", "description": "A unique ID for the transaction." }
      },
      "required": ["type", "amount", "status", "createdAt", "sessionId"]
    },
    "Chat": {
        "title": "Chat Session",
        "description": "Represents a chat session between two or more users.",
        "type": "object",
        "properties": {
            "participants": { "type": "array", "items": { "type": "string" }, "description": "Array of user UIDs participating in the chat." },
            "lastMessage": { "type": "string", "description": "The text of the last message sent." },
            "lastMessageAt": { "type": "string", "format": "date-time" }
        },
        "required": ["participants", "lastMessageAt"]
    },
    "ChatMessage": {
        "title": "Chat Message",
        "description": "Represents a single message within a chat session.",
        "type": "object",
        "properties": {
            "senderId": { "type": "string", "description": "The UID of the message sender." },
            "text": { "type": "string", "description": "The text content of the message." },
            "mediaUrl": { "type": "string", "format": "uri", "description": "URL of any attached media." },
            "mediaType": { "type": "string", "enum": ["image", "video", "audio", "file"] },
            "createdAt": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
            "isEdited": { "type": "boolean", "description": "True if the message has been edited." },
            "deletedFor": { "type": "array", "items": { "type": "string" }, "description": "An array of user UIDs for whom this message is deleted."}
        },
        "required": ["senderId", "createdAt"]
    },
    "Post": {
      "title": "Media Post",
      "description": "Represents a media post created by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who created the post." },
        "username": { "type": "string" },
        "userAvatar": { "type": "string", "format": "uri" },
        "type": { "type": "string", "enum": ["text", "image", "reels", "film", "music"] },
        "text": { "type": "string", "description": "The text content for text posts." },
        "backgroundColor": { "type": "string", "description": "Background color for text posts." },
        "mediaUrl": { "type": "string", "format": "uri", "description": "URL of the uploaded media file from Cloudinary." },
        "description": { "type": "string", "description": "Caption or description for the post." },
        "allowComments": { "type": "boolean" },
        "allowDownload": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "Array of user UIDs who liked the post." },
        "commentCount": { "type": "number" }
      },
      "required": ["userId", "type", "createdAt"]
    },
    "PostComment": {
        "title": "Post Comment",
        "description": "Represents a single comment on a media post.",
        "type": "object",
        "properties": {
            "postId": { "type": "string", "description": "The ID of the post this comment belongs to." },
            "userId": { "type": "string" },
            "username": { "type": "string" },
            "userAvatar": { "type": "string", "format": "uri" },
            "text": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["postId", "userId", "text", "createdAt"]
    },
    "MarketApp": {
      "title": "Marketplace App",
      "description": "Represents an application listed on the marketplace.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "iconUrl": { "type": "string", "format": "uri" },
        "screenshots": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "platform": { "type": "string", "enum": ["android", "ios"] },
        "description": { "type": "string" },
        "appFileUrl": { "type": "string", "format": "uri" },
        "price": { "type": "number" },
        "priceType": { "type": "string", "enum": ["free", "paid"] },
        "sellerId": { "type": "string" }
      },
      "required": ["name", "iconUrl", "platform", "description", "appFileUrl", "price", "priceType", "sellerId"]
    },
    "MarketProduct": {
      "title": "Marketplace Product",
      "description": "Represents a physical or digital product sold on the marketplace.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "price": { "type": "number" },
        "contactType": { "type": "string", "enum": ["chat", "call"] },
        "contactInfo": { "type": "string", "description": "Phone number if contact type is call" },
        "sellerId": { "type": "string" }
      },
      "required": ["name", "imageUrl", "price", "contactType", "sellerId"]
    },
    "MarketBook": {
      "title": "Marketplace Book",
      "description": "Represents a book sold on the marketplace.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "coverUrl": { "type": "string", "format": "uri" },
        "price": { "type": "number" },
        "priceType": { "type": "string", "enum": ["free", "paid"] },
        "sellerId": { "type": "string" }
      },
      "required": ["name", "content", "coverUrl", "priceType", "sellerId"]
    },
    "UpworkProfile": {
      "title": "Upwork Freelancer Profile",
      "description": "Represents a freelancer's profile on the Upwork section.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "certificateUrl": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" },
        "sellerId": { "type": "string" }
      },
      "required": ["name", "title", "description", "phoneNumber", "address", "avatarUrl", "certificateUrl", "videoUrl", "sellerId"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public user profile information, keyed by user ID."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": {
        "$ref": "#/entities/Notification"
      },
      "description": "Stores notifications for a specific user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Stores a user's transaction history."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores metadata for a single chat session between users."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores all messages for a specific chat session."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores all media posts from users."
    },
    "/postComments/{commentId}": {
      "schema": { "$ref": "#/entities/PostComment" },
      "description": "Stores comments for a specific post."
    },
    "/apps/{appId}": {
      "schema": { "$ref": "#/entities/MarketApp" },
      "description": "Stores marketplace app listings."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/MarketProduct" },
      "description": "Stores marketplace product listings."
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/MarketBook" },
      "description": "Stores marketplace book listings."
    },
    "/upworkProfiles/{profileId}": {
      "schema": { "$ref": "#/entities/UpworkProfile" },
      "description": "Stores freelancer profiles for the Upwork section."
    }
  }
}
