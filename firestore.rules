
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any signed-in user can read another user's profile.
      allow get: if isSignedIn();
      
      // A user can only create or update their own document.
      // For banning, a manager role would be required. For now, allow any user to update for prototype.
      allow create, update: if isSignedIn();
      
      // Deleting a user document is not allowed from the client.
      allow delete: if false;

      // Rules for the 'notifications' subcollection
      match /notifications/{notificationId} {
        // A user can manage their own notifications.
        allow read, create, update: if request.auth.uid == userId;
        allow delete: if false;
      }

      // Rules for the 'transactions' subcollection
      match /transactions/{transactionId} {
        // Users can create and read their own transactions.
        // They cannot be updated or deleted to maintain an immutable ledger.
        allow create, read: if request.auth.uid == userId;
        allow update, delete: if false;
      }
    }

    // Allow any signed-in user to list all users (for chat functionality).
    match /users {
      allow list: if isSignedIn();
    }
    
    // Rules for the 'chats' collection
    match /chats/{chatId} {
      // Allow any signed-in user to query the chat list.
      // The client-side code is responsible for filtering to only show chats for the current user.
      allow list: if isSignedIn();
      // Allow create if the user is one of the participants
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      // Allow read/update if the user is one of the participants
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    // Rules for the 'messages' collection (top-level)
    match /messages/{messageId} {
      // Allow create if user is a participant of the chat the message belongs to
      allow create: if isSignedIn() && get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants.includes(request.auth.uid);
      
      // Allow read if user is a participant of the chat the message belongs to
      allow read: if isSignedIn() && get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants.includes(request.auth.uid);

      // Allow sender to update/delete their own message
      allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Rules for media posts
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Allow updates for things like likes
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if false;
      }
    }
    
    // Rules for app config
    match /app_config/{docId} {
      // Anyone can read, only authenticated users can update (for prototype purposes)
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }
  }
}

    