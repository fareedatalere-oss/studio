{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "username": {
          "type": "string",
          "description": "The user's chosen username."
        },
        "country": {
          "type": "string",
          "description": "The user's country."
        },
        "pin": {
            "type": "string",
            "description": "The user's 5-digit transaction PIN (should be stored securely, e.g., hashed)."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the profile was created."
        }
      },
      "required": ["uid", "email", "username", "country", "pin", "createdAt"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public user profile information, keyed by user ID."
    }
  }
}
